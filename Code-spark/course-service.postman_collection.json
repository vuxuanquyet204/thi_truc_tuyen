{
  "info": {
    "_postman_id": "8c0b6d8b-0cf4-45f9-95c9-27215f4a665e",
    "name": "Course Service (via API Gateway)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/course"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "courseId",
      "value": "11111111-1111-1111-1111-111111111111"
    },
    {
      "key": "organizationId",
      "value": "22222222-2222-2222-2222-222222222222"
    },
    {
      "key": "studentId",
      "value": "33333333-3333-3333-3333-333333333333"
    },
    {
      "key": "materialId",
      "value": "44444444-4444-4444-4444-444444444444"
    },
    {
      "key": "quizId",
      "value": "55555555-5555-5555-5555-555555555555"
    },
    {
      "key": "imageId",
      "value": "66666666-6666-6666-6666-666666666666"
    },
    {
      "key": "questionId",
      "value": "77777777-7777-7777-7777-777777777777"
    },
    {
      "key": "optionId1",
      "value": "88888888-8888-8888-8888-888888888881"
    },
    {
      "key": "optionId2",
      "value": "88888888-8888-8888-8888-888888888882"
    }
  ],
  "item": [
    {
      "name": "Course",
      "item": [
        {
          "name": "Create Course",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Java Core Fundamentals\",\n  \"organizationId\": \"{{organizationId}}\",\n  \"description\": \"Khoá học nhập môn Java\",\n  \"thumbnailUrl\": \"https://example.com/thumb.jpg\",\n  \"visibility\": \"PUBLIC\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/courses"
          }
        },
        {
          "name": "Get Course By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/courses/{{courseId}}"
          }
        },
        {
          "name": "Get All Courses (Paged + Filter)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/courses?page=0&size=20&sort=createdAt,desc&keyword=&organizationId=&visibility=&createdFrom=&createdTo=",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "courses"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "20"
                },
                {
                  "key": "sort",
                  "value": "createdAt,desc"
                },
                {
                  "key": "keyword",
                  "value": ""
                },
                {
                  "key": "organizationId",
                  "value": ""
                },
                {
                  "key": "visibility",
                  "value": ""
                },
                {
                  "key": "createdFrom",
                  "value": ""
                },
                {
                  "key": "createdTo",
                  "value": ""
                }
              ]
            }
          }
        },
        {
          "name": "Get Courses By Organization",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/courses/organization/{{organizationId}}?page=0&size=10&sort=createdAt,desc"
          }
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Java Core Fundamentals - Updated\",\n  \"description\": \"Nội dung cập nhật\",\n  \"thumbnailUrl\": \"https://example.com/thumb-new.jpg\",\n  \"visibility\": \"PRIVATE\",\n  \"organizationId\": \"{{organizationId}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/courses/{{courseId}}"
          }
        },
        {
          "name": "Delete Course",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/courses/{{courseId}}"
          }
        },
        {
          "name": "Publish Course",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/courses/{{courseId}}/publish"
          }
        },
        {
          "name": "Get Course Roster",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/courses/{{courseId}}/roster"
          }
        },
        {
          "name": "Get Course Students (Paged)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/courses/{{courseId}}/students?page=0&size=20"
          }
        },
        {
          "name": "Upload Course Image",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": "{{baseUrl}}/api/v1/courses/{{courseId}}/images/upload"
          }
        },
        {
          "name": "Delete Course Image",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/courses/{{courseId}}/images/{{imageId}}"
          }
        }
      ]
    },
    {
      "name": "Material",
      "item": [
        {
          "name": "Add Material To Course",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Lecture 1 PDF\",\n  \"type\": \"pdf\",\n  \"storageKey\": \"materials/lecture1.pdf\",\n  \"content\": \"\",\n  \"displayOrder\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/courses/{{courseId}}/materials"
          }
        },
        {
          "name": "Get Materials For Course",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/courses/{{courseId}}/materials"
          }
        },
        {
          "name": "Update Material",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Lecture 1 PDF (Updated)\",\n  \"type\": \"pdf\",\n  \"storageKey\": \"materials/lecture1-v2.pdf\",\n  \"content\": \"\",\n  \"displayOrder\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/materials/{{materialId}}"
          }
        },
        {
          "name": "Delete Material",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/materials/{{materialId}}"
          }
        },
        {
          "name": "Upload Material File",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": "{{baseUrl}}/api/v1/courses/{{courseId}}/materials/upload"
          }
        }
      ]
    },
    {
      "name": "Quiz",
      "item": [
        {
          "name": "Get Quiz Details (Student)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/quizzes/{{quizId}}"
          }
        },
        {
          "name": "Submit Quiz",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": \"{{studentId}}\",\n  \"answers\": {\n    \"{{questionId}}\": [\"{{optionId1}}\", \"{{optionId2}}\"]\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/quizzes/{{quizId}}/submit"
          }
        },
        {
          "name": "Create Quiz",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Quiz Week 1\",\n  \"description\": \"Basic Java quiz\",\n  \"timeLimitMinutes\": 15,\n  \"questions\": [\n    {\n      \"content\": \"Java là ngôn ngữ gì?\",\n      \"type\": \"SINGLE_CHOICE\",\n      \"displayOrder\": 1,\n      \"options\": [\n        {\n          \"content\": \"Compiled + JVM\",\n          \"isCorrect\": true\n        },\n        {\n          \"content\": \"Pure scripting\",\n          \"isCorrect\": false\n        }\n      ]\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/courses/{{courseId}}/quizzes"
          }
        },
        {
          "name": "Get All Quizzes For Course",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/courses/{{courseId}}/quizzes"
          }
        },
        {
          "name": "Get Quiz Details (Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/quizzes/{{quizId}}/admin"
          }
        },
        {
          "name": "Update Quiz",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Quiz Week 1 (Updated)\",\n  \"description\": \"Updated description\",\n  \"timeLimitMinutes\": 20\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/quizzes/{{quizId}}"
          }
        },
        {
          "name": "Delete Quiz",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/quizzes/{{quizId}}"
          }
        },
        {
          "name": "Get Questions For Exam",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/quizzes/{{quizId}}/questions"
          }
        },
        {
          "name": "Get Questions For Exam (Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/quizzes/{{quizId}}/admin/questions"
          }
        }
      ]
    },
    {
      "name": "Progress",
      "item": [
        {
          "name": "Update Student Progress",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/progress/student/{{studentId}}/course/{{courseId}}/material/{{materialId}}"
          }
        },
        {
          "name": "Get Student Progress In Course",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/progress/student/{{studentId}}/course/{{courseId}}"
          }
        },
        {
          "name": "Get Course Progress Dashboard",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/courses/{{courseId}}/progress"
          }
        }
      ]
    },
    {
      "name": "Reward",
      "item": [
        {
          "name": "Get Rewards For Student",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/rewards/student/{{studentId}}"
          }
        }
      ]
    }
  ]
}
