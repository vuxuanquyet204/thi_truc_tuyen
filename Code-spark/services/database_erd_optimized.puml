package "profile_db" #F3E5F5 {

    entity "profiles" as profiles {
        * id : uuid <<PK>>
        * user_id : uuid <<UK>>
        + first_name : varchar(100)
        + last_name : varchar(100)
        + email : varchar(255)
        + bio : text
        + avatar_url : text
        + total_points : int <<DEFAULT: 0>>
        + courses_completed : int <<DEFAULT: 0>>
        + exams_passed : int <<DEFAULT: 0>>
        + created_at : timestamp
        + updated_at : timestamp
    }
    
    entity "profile_certificates" as profile_certificates {
        * id : uuid <<PK>>
        * profile_id : uuid <<FK>>
        * certificate_id : uuid <<FK>>
        + title : varchar(500)
        + issuer : varchar(255)
        + issued_at : timestamp
        + credential_url : text
    }
    
    entity "profile_badges" as profile_badges {
        * id : uuid <<PK>>
        * profile_id : uuid <<FK>>
        + badge_name : varchar(100)
        + badge_icon : varchar(255)
        + description : text
        + earned_at : timestamp
        + certificate_id : uuid
        + course_id : uuid
    }
    
    entity "profile_completed_courses" as profile_completed_courses {
        * id : uuid <<PK>>
